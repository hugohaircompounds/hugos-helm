# Helm — local-only configuration.
# Secrets (Google refresh token, ClickUp API token) are stored in the OS keychain,
# not here. This file only holds non-secret defaults and the Google OAuth client
# config (which can also be entered via the Settings UI at runtime).

# Timezone used by the scheduler (IANA name). Override in Settings.
HELM_TIMEZONE=America/New_York

# Optional: Google OAuth client credentials (Desktop app type).
# If you don't set these here, paste them into Settings > Google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Port used by the OAuth loopback listener during the consent flow.
# The redirect URI registered in the Google Cloud console must match:
#   http://127.0.0.1:<HELM_OAUTH_PORT>/callback
HELM_OAUTH_PORT=53217
